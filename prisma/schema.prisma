generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  imageUrl    String?
  url         String?  // product page for scraping brand/offers
  status      String   @default("Private") // Private, Researching, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  intelligence ProductIntelligence?
  creatives    CreativeSet[]
  actions      AdAction[]
}

model ProductIntelligence {
  id                 String   @id @default(cuid())
  productId          String   @unique
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  keyFeatures        String   // JSON array
  keyBenefits        String
  targetPainPoints   String
  primaryUseCases    String
  targetScenarios    String
  offers             String   // JSON
  valueProposition   String
  positioningStatement String?
  uniqueSellingPoints String  // JSON array
  competitiveAdvantages String // JSON array
  brandGuidelines    String?  // JSON
  confidence         Int?     @default(90)
  updatedAt          DateTime @updatedAt
}

model AdAction {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String   // "from_ad_library" | "from_recommendations" | "from_scratch"
  sourceUrl   String?  // Meta Ads Library URL
  adType      String?  // "variations" | "new_ads"
  language    String?
  variations  Int      @default(9)
  format      String?  // "1080x1080" | "1440x1800" | "1440x2560"
  customInstructions String?
  status      String   @default("pending") // pending, analyzing, generating, completed, failed
  analyzedAd  String?  // JSON: angle, hook, visual structure
  createdAt   DateTime @default(now())

  creativeSet CreativeSet?
}

model CreativeSet {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  actionId    String?  @unique
  action      AdAction? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  audience    String?  // e.g. "Older adults, retirees, back pain"
  angle       String?  // e.g. "WAKE UP PAIN-FREE!"
  concepts    String?  // e.g. "Lifestyle"
  createdAt   DateTime @default(now())

  creatives   Creative[]
}

model Creative {
  id            String   @id @default(cuid())
  creativeSetId String
  creativeSet   CreativeSet @relation(fields: [creativeSetId], references: [id], onDelete: Cascade)
  imageUrl      String   // generated image URL or path
  width         Int
  height        Int
  copy          String?  // headline/CTA
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}
